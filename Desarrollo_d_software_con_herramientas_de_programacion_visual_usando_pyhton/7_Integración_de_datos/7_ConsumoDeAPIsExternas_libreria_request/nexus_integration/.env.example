# Modo demo: ejecuta un proveedor HTTP local para no depender de APIs pagadas.
DEMO_PROVIDER_ENABLED=true
DEMO_PROVIDER_HOST=127.0.0.1
DEMO_PROVIDER_PORT=8765

# Activa fallos aleatorios, HTTP 500/429 y retardos artificiales.
CHAOS_MODE=false

# Si desactivas el proveedor demo, define estas URLs reales.
WEATHER_BASE_URL=
FLEET_BASE_URL=
IDENTITY_BASE_URL=

# Credenciales reales opcionales. Nunca se hardcodean en el código.
WEATHER_API_KEY=
FLEET_BEARER_TOKEN=
IDENTITY_API_KEY=

# Datos a sincronizar.
DRIVER_IDS=D-1001,D-1002,D-1003
VEHICLE_IDS=V-1001,V-1002,V-1003

# Red, resiliencia y caché.
REQUEST_CONNECT_TIMEOUT_SECONDS=3.05
REQUEST_READ_TIMEOUT_SECONDS=10
MAX_RETRIES=3
BACKOFF_FACTOR=0.5
JITTER_SECONDS=0.25
CACHE_TTL_SECONDS=300
RATE_LIMIT_PER_MINUTE=60

# Persistencia y observabilidad.
DATABASE_NAME=nexus_data.db
LOG_LEVEL=INFO
